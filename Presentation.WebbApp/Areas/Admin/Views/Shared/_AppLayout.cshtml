@{
    var pageTitle = ViewData["Title"]?.ToString();
    var title = !string.IsNullOrWhiteSpace(pageTitle)
        ? $"{pageTitle} | Admin Center"
        : "CoreFitness Admin Center | Gym & Fitness Center";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/fonts.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-site.css" asp-append-version="true" />
</head>
<body>
    <div class="admin-layout">
        <header>
            <partial name="_AdminHeaderSection" />
        </header>
                <aside>
            <nav class="admin-menu options-menu">
                <div class="options-menu-title">
                    Options Menu
                </div>
                <ul class="options">
                    <li class="option-title">Overview</li>
                    <li class="option-item">
                        <a class="option-item-link" asp-area="Admin" asp-controller="Admin" asp-action="Dashboard">Dashboard</a>
                    </li>
                    <li class="option-item">
                        <a class="option-item-link" asp-area="Admin" asp-controller="Admin" asp-action="Messages">Messages</a>
                    </li>
                    <li class="option-item">
                        <a class="option-item-link" asp-area="Admin" asp-controller="Admin" asp-action="Schedule">Schedule</a>
                    </li>
                 </ul>

                <ul class="options">
                    <li class="option-title">Management</li>
                    <li class="option-item">
                        <a class="option-item-link" asp-area="Admin" asp-controller="AdminEmployees" asp-action="Index">Employees</a>
                    </li>
                    <li class="option-item">
                        <a class="option-item-link" asp-area="Admin" asp-controller="AdminMembers" asp-action="Index">Members</a>
                    </li>
                    <li class="option-item">
                        <a class="option-item-link" asp-area="Admin" asp-controller="AdminMemberships" asp-action="Index">Memberships</a>
                    </li>
                    <li class="option-item">
                        <a class="option-item-link" asp-area="Admin" asp-controller="AdminInvoices" asp-action="Index">Invoices</a>
                    </li>
                </ul>
            </nav>
        </aside>
        <main>
            @RenderBody()
        </main>
    </div>

    <script src="~/js/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>