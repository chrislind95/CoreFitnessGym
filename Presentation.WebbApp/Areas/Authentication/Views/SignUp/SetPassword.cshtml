@model SetPasswordForm
@{
    ViewData["Title"] = "Set Password";
}

<section class="_auth">
    <div class="title">
        <h1>Set Your Password</h1>
        <p class="description">Set a strong password to protect your account. For security reasons, your password must be at least 8 characters long and include uppercase and lowercase letters, numbers, and special characters.</p>
    </div>

    <hr />

    <form method="post" asp-area="Authentication" asp-controller="SignUp" asp-action="SetPassword" novalidate>
        @Html.AntiForgeryToken()

        <div data-type="password" class="form-group">
            <label class="form-label" asp-for="Password"></label>
            <input class="form-input" asp-for="Password" />
            <span class="form-field-validation" asp-validation-for="Password"></span>
        </div>

        <div data-type="confirm-password" class="form-group">
            <label class="form-label" asp-for="ConfirmPassword"></label>
            <input class="form-input" asp-for="ConfirmPassword" />
            <span class="form-field-validation" asp-validation-for="ConfirmPassword"></span>
        </div>

        <button class="btn" type="submit">Continue</button>

        <div class="form-errormessage">
            <span class="field-validation-error" asp-validation-for="ErrorMessage"></span>
        </div>

    </form>
</section>